{
  "id": "checkbox",
  "name": "Checkbox",
  "description": "Controls an independent boolean choice with checked, unchecked, indeterminate, and disabled states.",
  "aliases": ["boolean control", "tick box", "multi-select option"],
  "useWhen": [
    "toggle an independent option",
    "select multiple items",
    "represent a partially selected group"
  ],
  "avoidWhen": [
    "select exactly one option from a group",
    "switch between mutually exclusive modes",
    "trigger an immediate action"
  ],
  "entry": "Checkbox.tsx",
  "preview": "Checkbox.preview.tsx",
  "stories": "Checkbox.stories.ts",
  "docs": "README.md",
  "changelog": "CHANGELOG.md",
  "status": "ready",
  "states": ["unchecked", "checked", "indeterminate", "disabled"],
  "variants": ["small", "medium"],
  "props": {
    "label": {
      "type": "ReactNode",
      "slot": true
    },
    "description": {
      "type": "ReactNode",
      "slot": true
    },
    "indeterminate": {
      "type": "boolean",
      "default": false
    },
    "size": {
      "type": "CheckboxSize",
      "values": ["small", "medium"],
      "default": "medium"
    },
    "checked": {
      "type": "boolean"
    },
    "defaultChecked": {
      "type": "boolean"
    },
    "disabled": {
      "type": "boolean"
    },
    "onChange": {
      "type": "ChangeEventHandler<HTMLInputElement>"
    }
  }
}
