{
  "id": "directory-panel",
  "name": "Directory Panel",
  "description": "Provides resizable, searchable semantic navigation for the active module and selected Project or Library source.",
  "aliases": ["project tree", "entity navigator", "filesystem panel", "component directory"],
  "useWhen": [
    "browse component or token categories",
    "search entities within one module",
    "resize project navigation",
    "switch the active source"
  ],
  "avoidWhen": [
    "navigate primary application modules",
    "show raw implementation files",
    "render an unrelated generic file explorer"
  ],
  "entry": "DirectoryPanel.tsx",
  "preview": "DirectoryPanel.preview.tsx",
  "stories": "DirectoryPanel.stories.ts",
  "docs": "README.md",
  "changelog": "CHANGELOG.md",
  "status": "ready",
  "states": ["default", "resizing", "empty", "loading", "overflow", "searching", "collapsed"],
  "variants": ["semantic-tree"],
  "props": {
    "isResizing": {
      "type": "boolean",
      "required": true
    },
    "navigationWidth": {
      "type": "number",
      "required": true
    },
    "minNavigationWidth": {
      "type": "number",
      "required": true
    },
    "maxNavigationWidth": {
      "type": "number",
      "required": true
    },
    "onResizeStart": {
      "type": "(event: PointerEvent<HTMLDivElement>) => void",
      "required": true
    },
    "onResizeKeyDown": {
      "type": "(event: KeyboardEvent<HTMLDivElement>) => void",
      "required": true
    },
    "projects": {
      "type": "DirectorySource[]",
      "required": true
    },
    "activeProject": {
      "type": "DirectorySource | null",
      "required": true
    },
    "activeModuleLabel": {
      "type": "string",
      "required": true
    },
    "tree": {
      "type": "DirectoryTreeItem[]",
      "required": true
    },
    "treeLoading": {
      "type": "boolean",
      "required": true
    },
    "onProjectChange": {
      "type": "(projectId: string) => void",
      "required": true
    },
    "onCreateProject": {
      "type": "() => void",
      "required": true
    },
    "selectedEntityId": {
      "type": "string | null"
    },
    "selectedFolderPath": {
      "type": "string | null"
    },
    "onTreeItemSelect": {
      "type": "(item: DirectoryTreeItem) => void"
    },
    "searchEnabled": {
      "type": "boolean",
      "default": true
    },
    "searchPlaceholder": {
      "type": "string"
    },
    "coloringEnabled": {
      "type": "boolean",
      "default": true
    },
    "actionsEnabled": {
      "type": "boolean",
      "default": true
    },
    "defaultCollapsed": {
      "type": "boolean",
      "default": true
    },
    "persistItemColors": {
      "type": "boolean",
      "default": true
    },
    "colorStorageKey": {
      "type": "string",
      "default": "design-lab:directory-item-colors"
    },
    "itemColors": {
      "type": "Record<string, string>"
    },
    "onItemColorChange": {
      "type": "(item: DirectoryTreeItem, color: string | null) => void"
    },
    "renderItemActions": {
      "type": "(item: DirectoryTreeItem) => ReactNode"
    }
  }
}
