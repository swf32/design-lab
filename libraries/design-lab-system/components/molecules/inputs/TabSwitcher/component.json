{
  "id": "tab-switcher",
  "name": "Tab Switcher",
  "description": "Select one value from a small mutually exclusive set using a segmented control or compact toggle.",
  "aliases": ["segmented control", "toggle switch", "theme switcher", "mode selector"],
  "useWhen": [
    "switch between themes",
    "switch canvas backgrounds",
    "select one mutually exclusive option"
  ],
  "avoidWhen": [
    "navigate between pages",
    "control a tabpanel without the required tabs keyboard contract"
  ],
  "entry": "TabSwitcher.tsx",
  "preview": "TabSwitcher.preview.tsx",
  "stories": "TabSwitcher.stories.ts",
  "docs": "README.md",
  "changelog": "CHANGELOG.md",
  "status": "ready",
  "variants": ["segmented", "toggle"],
  "states": ["default", "selected", "hover", "focus-visible", "disabled"],
  "previewMotion": {
    "trigger": "card-hover-focus",
    "kind": "state-transition",
    "durationToken": "transition.preview",
    "easingToken": "easing.preview",
    "reducedMotion": "static-baseline"
  },
  "props": {
    "options": {
      "type": "readonly TabSwitcherOption[]",
      "required": true
    },
    "value": {
      "type": "string",
      "required": true
    },
    "onChange": {
      "type": "(value: string) => void",
      "required": true
    },
    "ariaLabel": {
      "type": "string",
      "required": true
    },
    "variant": {
      "type": "TabSwitcherVariant",
      "values": ["segmented", "toggle"],
      "default": "segmented"
    },
    "size": {
      "type": "TabSwitcherSize",
      "values": ["small", "medium"],
      "default": "medium"
    },
    "className": {
      "type": "string",
      "default": ""
    }
  }
}
