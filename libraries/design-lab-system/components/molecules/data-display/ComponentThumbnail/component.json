{
  "id": "component-thumbnail",
  "name": "Component Thumbnail",
  "description": "Provides a non-interactive token-driven fallback illustration when an authored component preview is unavailable.",
  "aliases": ["fallback preview", "component illustration", "generic thumbnail"],
  "useWhen": [
    "render a catalog fallback",
    "illustrate an unknown component kind",
    "keep automatic discovery visible without authored preview code"
  ],
  "avoidWhen": [
    "an authored preview exists",
    "render an interactive production component",
    "show an image asset thumbnail"
  ],
  "entry": "ComponentThumbnail.tsx",
  "preview": "ComponentThumbnail.preview.tsx",
  "stories": "ComponentThumbnail.stories.ts",
  "docs": "README.md",
  "changelog": "CHANGELOG.md",
  "status": "ready",
  "states": ["default", "generic-fallback"],
  "variants": ["component-kind"],
  "props": {
    "kind": {
      "type": "string",
      "required": true
    }
  }
}
