    "kind": { "type": "\"component\" | \"slot\" | \"element\"", "required": true },
    "name": { "type": "string", "required": true },
    "code": { "type": "string", "required": true },
    "language": { "type": "\"tsx\" | \"html\" | \"scss\"", "required": true }
  }
}
