{
  "id": "asset-card",
  "name": "Asset Card",
  "description": "Displays one automatically discovered icon, image, video, or fallback asset with its filesystem identity.",
  "aliases": ["media card", "asset tile", "image card", "icon card"],
  "useWhen": [
    "browse library assets",
    "select an image or icon",
    "show a safe local asset preview"
  ],
  "avoidWhen": [
    "display a reusable UI component",
    "edit asset metadata",
    "render arbitrary remote media"
  ],
  "entry": "AssetCard.tsx",
  "preview": "AssetCard.preview.tsx",
  "stories": "AssetCard.stories.ts",
  "docs": "README.md",
  "changelog": "CHANGELOG.md",
  "status": "ready",
  "states": ["default", "selected"],
  "variants": ["icon", "image", "video", "other"],
  "props": {
    "name": {
      "type": "string",
      "required": true
    },
    "path": {
      "type": "string",
      "required": true
    },
    "kind": {
      "type": "AssetKind",
      "values": ["icon", "image", "video", "other"],
      "required": true
    },
    "extension": {
      "type": "string"
    },
    "previewUrl": {
      "type": "string | null"
    },
    "selected": {
      "type": "boolean",
      "default": false
    },
    "onClick": {
      "type": "() => void"
    }
  }
}
