{
  "schemaVersion": 1,
  "id": "auth",
  "name": "Auth",
  "status": "review",
  "description": "Sign-in screen. A successful submit exits to Account; an invalid one stays on this Page with an inline error.",
  "entry": "Auth.page.tsx",
  "docs": "README.md",
  "changelog": "CHANGELOG.md",
  "route": "/login",
  "defaultState": "default",
  "controls": [
    {
      "id": "formError",
      "kind": "boolean",
      "label": "Show form error",
      "description": "Whether the last submitted credentials were rejected."
    }
  ],
  "states": [
    {
      "id": "default",
      "name": "Sign in",
      "description": "Empty sign-in form.",
      "values": { "formError": false }
    },
    {
      "id": "error",
      "name": "Invalid credentials",
      "description": "The form shows a validation error after a rejected submit.",
      "values": { "formError": true }
    }
  ],
  "flow": {
    "nodes": [
      { "id": "default-node", "state": "default", "x": 80, "y": 160 },
      { "id": "error-node", "state": "error", "x": 80, "y": 480 }
    ],
    "edges": [
      {
        "id": "submit-invalid",
        "from": "default-node",
        "action": "submit",
        "label": "Submit (invalid)",
        "to": { "kind": "state", "stateId": "error" }
      },
      {
        "id": "submit-valid",
        "from": "default-node",
        "action": "submit-valid",
        "label": "Submit (valid, dev mode)",
        "to": { "kind": "page", "pageId": "account" }
      },
      {
        "id": "back-home",
        "from": "default-node",
        "action": "back",
        "label": "Back",
        "to": { "kind": "page", "pageId": "home" }
      }
    ]
  }
}
