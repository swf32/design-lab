{
  "name": "design-lab-workspace",
  "private": true,
  "workspaces": [
    "design-lab",
    "libraries/*"
  ],
  "scripts": {
    "dev": "npm run sync:components && npm run sync:assets && npm run dev --workspace=design-lab",
    "sync:components": "npm run build:components-index --workspace=@design-lab/system",
    "sync:assets": "npm run build:icon-index --workspace=@design-lab/system",
    "check:components": "npm run check:components-index --workspace=@design-lab/system",
    "check:assets": "npm run check:icon-index --workspace=@design-lab/system",
    "format": "npm run format:code && npm run format:styles",
    "format:code": "prettier --write \"design-lab/**/*.{json,mjs,ts,tsx}\" \"libraries/design-lab-system/**/*.{json,mjs,ts,tsx}\" \"scripts/**/*.mjs\"",
    "format:styles": "node scripts/format-styles.mjs --write",
    "check:code": "prettier --check \"design-lab/**/*.{json,mjs,ts,tsx}\" \"libraries/design-lab-system/**/*.{json,mjs,ts,tsx}\" \"scripts/**/*.mjs\"",
    "check:styles": "node scripts/format-styles.mjs --check",
    "build": "npm run sync:components && npm run sync:assets && npm run check:code && npm run check:styles && npm run build --workspace=design-lab",
    "test": "npm run sync:components && npm run sync:assets && npm run check:code && npm run check:styles && npm run test --workspace=design-lab",
    "mcp": "npm run mcp --workspace=design-lab",
    "designlab": "npm run designlab --workspace=design-lab --"
  },
  "devDependencies": {
    "postcss": "^8.5.20",
    "prettier": "^3.9.5"
  }
}
